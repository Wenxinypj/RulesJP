#!name=日本流媒体
#!desc=日本流媒体分流集合（TVer / FOD / U-NEXT / Hulu Japan / Telasa / DMM / NHK ONE / AbemaTV）
#!date=2026-05-16

# ============================================
# > TVer（日本5大电视台联合流媒体）
# 新视频平台 Streaks（2025年3月起），地区检测严格
# ============================================
DOMAIN-SUFFIX,tver.jp,日本流媒体
DOMAIN-SUFFIX,boltdns.net,日本流媒体
DOMAIN-SUFFIX,brightcove.net,日本流媒体
DOMAIN,edge.api.brightcove.com,日本流媒体
DOMAIN,players.brightcove.net,日本流媒体
DOMAIN-SUFFIX,conviva.com,日本流媒体
DOMAIN-SUFFIX,interactive-circle.jp,日本流媒体

# ============================================
# > FOD（フジテレビオンデマンド）
# ============================================
USER-AGENT,FOD*,日本流媒体
USER-AGENT,*FOD/*,日本流媒体
DOMAIN-SUFFIX,fujitv.co.jp,日本流媒体
DOMAIN,fod.zendesk.com,日本流媒体
DOMAIN,measure.ic.tver.jp,日本流媒体

# ============================================
# > U-NEXT（日本最大VOD平台，地区检测严格）
# ============================================
DOMAIN-SUFFIX,unext.jp,日本流媒体
DOMAIN-SUFFIX,nxtv.jp,日本流媒体
DOMAIN-KEYWORD,nxtv-jp.akamaized.net,日本流媒体

